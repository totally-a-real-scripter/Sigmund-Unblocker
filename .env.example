NODE_ENV=production
PORT=3000
HOST=0.0.0.0
PUBLIC_PORT=3000
WISP_PUBLIC_PORT=4000
WISP_WS_URL=ws://wisp:4000
NODE_BASE_IMAGE=node:22-alpine
PYTHON_BASE_IMAGE=python:3.12-slim

ALLOWED_ORIGINS=*
MAX_RPS=60
CACHE_ENABLED=true
CACHE_TTL_MS=30000
REQUEST_TIMEOUT_MS=20000
PROXY_USER_AGENT=Sigmund-Unblocker/1.0
DOMAIN_ALLOWLIST=
DOMAIN_BLOCKLIST=
HEADER_OVERRIDES={"x-proxy":"sigmund"}
